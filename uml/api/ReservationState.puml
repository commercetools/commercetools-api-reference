@startuml

hide methods
enum ReservationState {
    CREATED
    UPDATED
    RELEASED
    EXPIRED
    COMMITTED
}
interface Reservation [[Reservation.svg]]  {
    id: String
    version: Long
    createdAt: DateTime
    lastModifiedAt: DateTime
    expiresAt: DateTime
    lastModifiedBy: [[LastModifiedBy.svg LastModifiedBy]]
    createdBy: [[CreatedBy.svg CreatedBy]]
    inventoryEntry: [[InventoryEntryReference.svg InventoryEntryReference]]
    quantity: Long
    owner: [[Reference.svg Reference]]
    lineItemId: String
    state: [[ReservationState.svg ReservationState]]
}
ReservationState --> Reservation #green;text:green : "state"
@enduml
