<?xml version="1.0" encoding="UTF-8" ?>
<ruleset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/commercetools/rmf-codegen/main/ctp-validators/src/main/resources/ruleset.xsd">
    <name>default</name>
    <apply set="default"/>
    <rules>
        <rule>
            <name>com.commercetools.rmf.validators.PropertyPluralRule</name>
            <options>
                <option type="exclude">state</option>
                <option type="exclude">discountedPricePerQuantity</option>
                <option type="exclude">value</option>
            </options>
        </rule>
        <rule>
            <name>com.commercetools.rmf.validators.StringPropertySingularRule</name>
            <options>
                <option type="exclude">taxCalculationMode</option>
                <option type="exclude">status</option>
            </options>
        </rule>
        <rule>
            <name>com.commercetools.rmf.validators.UnionTypePropertyRule</name>
            <options>
                <option type="exclude">//</option>
            </options>
        </rule>
        <rule>
            <name>com.commercetools.rmf.validators.ResourceLowerCaseHyphenRule</name>
            <options>
              <option type="exclude">/{projectKey}/import-summaries/importSinkKey={importSinkKey}</option>
              <option type="exclude">/{projectKey}/categories/importSinkKey={importSinkKey}</option>
              <option type="exclude">/{projectKey}/prices/importSinkKey={importSinkKey}</option>
              <option type="exclude">/{projectKey}/products/importSinkKey={importSinkKey}</option>
              <option type="exclude">/{projectKey}/product-drafts/importSinkKey={importSinkKey}</option>
              <option type="exclude">/{projectKey}/product-types/importSinkKey={importSinkKey}</option>
              <option type="exclude">/{projectKey}/product-variants/importSinkKey={importSinkKey}</option>
              <option type="exclude">/{projectKey}/product-variant-patches/importSinkKey={importSinkKey}</option>
              <option type="exclude">/{projectKey}/orders/importSinkKey={importSinkKey}</option>
              <option type="exclude">/{projectKey}/order-patches/importSinkKey={importSinkKey}</option>
              <option type="exclude">/{projectKey}/customers/importSinkKey={importSinkKey}</option>
              <option type="exclude">/{projectKey}/inventories/importSinkKey={importSinkKey}</option>
            </options>
        </rule>
        <rule enabled="false">
            <name>com.commercetools.rmf.validators.DatetimeRule</name>
        </rule>
        <rule>
            <name>com.commercetools.rmf.validators.CamelCaseRule</name>
            <options>
              <option type="exclude">error_description</option>
            </options>
        </rule>
      <rule>
        <name>com.commercetools.rmf.validators.BooleanPropertyNameRule</name>
        <options>
          <!--                   TypeName:propertyName -->
          <option type="exclude">ProductVariantImport:isMasterVariant</option>
          <option type="exclude">AttributeDefinition:isRequired</option>
          <option type="exclude">AttributeDefinition:isSearchable</option>
          <option type="exclude">CustomerImport:isEmailVerified</option>
          <option type="exclude">CartClassificationTier:isMatching</option>
          <option type="exclude">TrackingData:isReturn</option>
          <option type="exclude">DiscountCodeImport:isActive</option>
          <option type="exclude">ProductSelectionImport:isActive</option>
          <option type="exclude">BusinessUnitImport:isActive</option>
        </options>
      </rule>
      <rule>
        <name>com.commercetools.rmf.validators.EnumValuePascalCaseRule</name>
        <options>
          <!--                   EnumTypeName:enumValue -->
          <option type="exclude">MoneyType:centPrecision</option>
          <option type="exclude">MoneyType:highPrecision</option>
          <option type="exclude">ImportResourceType:business-unit</option>
          <option type="exclude">ImportResourceType:category</option>
          <option type="exclude">ImportResourceType:customer</option>
          <option type="exclude">ImportResourceType:discount-code</option>
          <option type="exclude">ImportResourceType:inventory</option>
          <option type="exclude">ImportResourceType:order</option>
          <option type="exclude">ImportResourceType:order-patch</option>
          <option type="exclude">ImportResourceType:price</option>
          <option type="exclude">ImportResourceType:product</option>
          <option type="exclude">ImportResourceType:product-draft</option>
          <option type="exclude">ImportResourceType:product-selection</option>
          <option type="exclude">ImportResourceType:product-type</option>
          <option type="exclude">ImportResourceType:product-variant</option>
          <option type="exclude">ImportResourceType:product-variant-patch</option>
          <option type="exclude">ImportResourceType:standalone-price</option>
          <option type="exclude">ImportResourceType:type</option>
          <option type="exclude">ReferenceType:associate-role</option>
          <option type="exclude">ReferenceType:business-unit</option>
          <option type="exclude">ReferenceType:cart</option>
          <option type="exclude">ReferenceType:cart-discount</option>
          <option type="exclude">ReferenceType:category</option>
          <option type="exclude">ReferenceType:channel</option>
          <option type="exclude">ReferenceType:customer</option>
          <option type="exclude">ReferenceType:customer-group</option>
          <option type="exclude">ReferenceType:discount-code</option>
          <option type="exclude">ReferenceType:key-value-document</option>
          <option type="exclude">ReferenceType:order</option>
          <option type="exclude">ReferenceType:payment</option>
          <option type="exclude">ReferenceType:price</option>
          <option type="exclude">ReferenceType:product</option>
          <option type="exclude">ReferenceType:product-discount</option>
          <option type="exclude">ReferenceType:product-type</option>
          <option type="exclude">ReferenceType:product-variant</option>
          <option type="exclude">ReferenceType:shipping-method</option>
          <option type="exclude">ReferenceType:state</option>
          <option type="exclude">ReferenceType:store</option>
          <option type="exclude">ReferenceType:tax-category</option>
          <option type="exclude">ReferenceType:type</option>
          <option type="exclude">ProcessingState:processing</option>
          <option type="exclude">ProcessingState:validationFailed</option>
          <option type="exclude">ProcessingState:unresolved</option>
          <option type="exclude">ProcessingState:waitForMasterVariant</option>
          <option type="exclude">ProcessingState:imported</option>
          <option type="exclude">ProcessingState:rejected</option>
          <option type="exclude">ProcessingState:canceled</option>
          <option type="exclude">ImportOperationState:processing</option>
          <option type="exclude">ImportOperationState:validationFailed</option>
          <option type="exclude">StrategyEnum:ttl</option>
          <option type="exclude">VariantSelectionType:includeOnly</option>
          <option type="exclude">VariantSelectionType:includeAllExcept</option>
          <option type="exclude">ResourceTypeId:address</option>
          <option type="exclude">ResourceTypeId:asset</option>
          <option type="exclude">ResourceTypeId:business-unit</option>
          <option type="exclude">ResourceTypeId:cart-discount</option>
          <option type="exclude">ResourceTypeId:category</option>
          <option type="exclude">ResourceTypeId:channel</option>
          <option type="exclude">ResourceTypeId:customer</option>
          <option type="exclude">ResourceTypeId:customer-group</option>
          <option type="exclude">ResourceTypeId:custom-line-item</option>
          <option type="exclude">ResourceTypeId:discount-code</option>
          <option type="exclude">ResourceTypeId:inventory-entry</option>
          <option type="exclude">ResourceTypeId:line-item</option>
          <option type="exclude">ResourceTypeId:order</option>
          <option type="exclude">ResourceTypeId:order-edit</option>
          <option type="exclude">ResourceTypeId:order-delivery</option>
          <option type="exclude">ResourceTypeId:order-parcel</option>
          <option type="exclude">ResourceTypeId:order-return-item</option>
          <option type="exclude">ResourceTypeId:payment</option>
          <option type="exclude">ResourceTypeId:payment-interface-interaction</option>
          <option type="exclude">ResourceTypeId:product-price</option>
          <option type="exclude">ResourceTypeId:product-selection</option>
          <option type="exclude">ResourceTypeId:quote</option>
          <option type="exclude">ResourceTypeId:review</option>
          <option type="exclude">ResourceTypeId:shipping</option>
          <option type="exclude">ResourceTypeId:shipping-method</option>
          <option type="exclude">ResourceTypeId:shopping-list</option>
          <option type="exclude">ResourceTypeId:shopping-list-text-line-item</option>
          <option type="exclude">ResourceTypeId:standalone-price</option>
          <option type="exclude">ResourceTypeId:store</option>
          <option type="exclude">ResourceTypeId:transaction</option>
          <option type="exclude">CustomFieldReferenceValue:associate-role</option>
          <option type="exclude">CustomFieldReferenceValue:business-unit</option>
          <option type="exclude">CustomFieldReferenceValue:cart</option>
          <option type="exclude">CustomFieldReferenceValue:category</option>
          <option type="exclude">CustomFieldReferenceValue:channel</option>
          <option type="exclude">CustomFieldReferenceValue:customer</option>
          <option type="exclude">CustomFieldReferenceValue:customer-group</option>
          <option type="exclude">CustomFieldReferenceValue:key-value-document</option>
          <option type="exclude">CustomFieldReferenceValue:order</option>
          <option type="exclude">CustomFieldReferenceValue:product</option>
          <option type="exclude">CustomFieldReferenceValue:product-type</option>
          <option type="exclude">CustomFieldReferenceValue:review</option>
          <option type="exclude">CustomFieldReferenceValue:state</option>
          <option type="exclude">CustomFieldReferenceValue:shipping-method</option>
          <option type="exclude">CustomFieldReferenceValue:zone</option>
        </options>
      </rule>
    </rules>
</ruleset>
