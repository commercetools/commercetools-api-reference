#%RAML 1.0 DataType
(package): Change
type: Change
displayName: SetLocalizedDescriptionChange
discriminatorValue: SetLocalizedDescriptionChange
properties:
  type:
    type: string
    enum:
      - SetLocalizedDescriptionChange
  change:
    type: string
    enum:
      - setDescription
  previousValue:
    type: LocalizedString
    description: Value before the change.
  nextValue:
    type: LocalizedString
    description: Value after the change.
  catalogData:
    type: string
    description: |
      Product data that was updated.

      - `staged`, if the staged [ProductCatalogData](ctp:api:type:ProductCatalogData) was updated.
      - `current`, if the current [ProductCatalogData](ctp:api:type:ProductCatalogData) was updated.

      This field is only present if the change is related to the Product entity.
