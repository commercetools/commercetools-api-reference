<?xml version="1.0" encoding="UTF-8" ?>
<ruleset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/commercetools/rmf-codegen/main/ctp-validators/src/main/resources/ruleset.xsd">
    <name>default</name>
    <apply set="default"/>
    <rules>
        <rule>
            <name>com.commercetools.rmf.validators.ResourcePluralRule</name>
            <options>
                <option type="exclude">insights-configuration</option>
            </options>
        </rule>
        <rule enabled="false">
            <name>com.commercetools.rmf.validators.DatetimeRule</name>
        </rule>
        <rule>
            <name>com.commercetools.rmf.validators.EnumValuePascalCaseRule</name>
            <options>
                <!--                   EnumTypeName:enumValue -->
                <option type="exclude">ServiceRegion:local-dev</option>
                <option type="exclude">ServiceRegion:ctp-gcp-production-us-v1</option>
                <option type="exclude">ServiceRegion:ctp-gcp-production-eu-v1</option>
                <option type="exclude">ServiceRegion:ctp-production-au</option>
                <option type="exclude">ServiceRegion:ctp-aws-production-fra</option>
                <option type="exclude">ServiceRegion:ctp-aws-production-ohio</option>
                <option type="exclude">ServiceRegion:ctp-gcp-performance-test</option>
                <option type="exclude">ServiceRegion:ctp-staging</option>
                <option type="exclude">NewRelicRegion:eu</option>
                <option type="exclude">NewRelicRegion:us</option>
                <option type="exclude">DatadogSite:US1</option>
                <option type="exclude">DatadogSite:US3</option>
                <option type="exclude">DatadogSite:US5</option>
                <option type="exclude">DatadogSite:EU1</option>
                <option type="exclude">DatadogSite:US1-FED</option>
                <option type="exclude">DatadogSite:AP1</option>
            </options>
        </rule>
    </rules>
</ruleset>
