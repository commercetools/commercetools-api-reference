#%RAML 1.0 Trait

queryParameters:
  filter[supplyChannels]:
    type: string[]
    required: false
    description: |
      Supply [Channel](ctp:api:type:Channel) IDs to include in the availability data.
      If omitted, only the no-channel availability is returned.
      If provided, per-channel availability is added alongside the no-channel availability.
