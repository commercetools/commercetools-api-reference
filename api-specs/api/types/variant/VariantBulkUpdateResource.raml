#%RAML 1.0 DataType
(package): Variant
type: object
(beta): true
displayName: VariantBulkUpdateResource
example: !include ../../examples/Variant/VariantBulkUpdateResource.json
description: |
  A lightweight reference containing the `id` and updated `version` of a Variant after a successful bulk update.
properties:
  id:
    type: string
    description: |
      Unique identifier of the updated Variant.
  version:
    type: number
    format: int64
    description: |
      The new version of the Variant after the update.
