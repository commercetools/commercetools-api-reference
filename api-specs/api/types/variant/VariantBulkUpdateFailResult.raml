#%RAML 1.0 DataType
(package): Variant
type: VariantBulkUpdateResult
(beta): true
displayName: VariantBulkUpdateFailResult
discriminatorValue: Fail
example: !include ../../examples/Variant/VariantBulkUpdateFailResult.json
description: |
  Result for a Variant that failed to update in a bulk update request.
properties:
  errors:
    type: array
    items: ErrorObject
    description: |
      Errors that caused the update to fail for this Variant.
