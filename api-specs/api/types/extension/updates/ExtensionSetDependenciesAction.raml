#%RAML 1.0 DataType
(package): Extension
type: ExtensionUpdateAction
displayName: ExtensionSetDependenciesAction
discriminatorValue: setDependencies
(beta): true
example: !include ../../../examples/Extension/ExtensionSetDependenciesAction.json
properties:
  dependencies:
    type: ExtensionResourceIdentifier[]
    maxItems: 5
    description: |
      Extensions this Extension depends on, identified by `id` or `key`. Set to an empty array to remove all dependencies. Maximum 5 entries.
