#%RAML 1.0 DataType
(package): McpServer
type: object
displayName: McpServerType
example: !include ../../examples/McpServer/McpServerType.json
description: |
  Describes an MCP Server type and one of its major versions, including the catalog of tools available for it. Use this catalog to discover which tools you can enable on a [McpServer](ctp:api:type:McpServer) of this type.
properties:
  type:
    type: string
    description: |
      Identifier of the MCP Server type, such as `CommerceMCP`.
  majorVersion:
    type: string
    description: |
      Major version of the MCP Server type, such as `v4`.
  tools:
    type: array
    items: McpServerTypeTool
    description: |
      Tools available for this MCP Server type and major version.
