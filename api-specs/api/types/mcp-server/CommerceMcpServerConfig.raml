#%RAML 1.0 DataType
(package): McpServer
type: McpServerConfig
displayName: CommerceMcpServerConfig
discriminatorValue: CommerceMCP
example: !include ../../examples/McpServer/CommerceMcpServerConfig.json
description: |
  Connection configuration of a Commerce MCP Server. Exposes the [Commerce MCP Server tools](/../dev-tooling/mcp/commerce-mcp#available-tools) to AI agents.
properties:
  majorVersion:
    type: string
    enum:
      - v1
      - v4
    (enumDescriptions):
      v1: |
        Version 1 of the Commerce MCP Server configuration. Deprecated. Use `v4` instead.
      v4: |
        Version 4 of the Commerce MCP Server configuration.
    description: |
      Major version of this MCP Server type. Supported versions are `v1` (deprecated) and `v4`.
  url:
    type: string
    description: |
      URL of the MCP Server. Generated by the system from the region, domain, Project key, and MCP Server key.
      Format: `https://mcp.{region}.{domain}/projects/{projectKey}/{mcpServerKey}`
  tools:
    type: array
    items: McpServerTool
    description: |
      List of tools enabled for this MCP Server. Use `all` to enable all available tools, or specify individual tool names such as `read_products` or `create_orders`. To reduce the number of LLM turns and improve overall performance, it is advisable to expose only the tools that are necessary, or at least minimize the exposure of tools that are unlikely to be used.
  toolCustomizations:
    type: array
    items: ToolCustomization
    description: |
      Per-tool customizations applied at `tools/list` and `tools/call` time, such as overriding a tool's description or constraining its parameters.
  jsonOutputFiltering?:
    type: McpServerJsonOutputFiltering
    description: |
      Response field-filtering rules applied to tool responses.
  toolOutputFormatting?:
    type: McpServerToolOutputFormatting
    description: |
      Output formatting applied to tool responses. When absent, responses are left untouched.
