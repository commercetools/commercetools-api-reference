#%RAML 1.0 DataType
(package): McpServer
type: object
displayName: RemoveToolCustomizationTarget
description: |
  Identifies a [tool customization](ctp:api:type:ToolCustomization) to remove by its tool name.
properties:
  tool:
    type: McpServerTool
    description: |
      Name of the tool whose customization is removed.
