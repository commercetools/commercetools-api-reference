#%RAML 1.0 DataType
(package): McpServer
type: McpServerUpdateAction
displayName: McpServerSetNameAction
discriminatorValue: setName
example: !include ../../../examples/McpServer/McpServerSetNameAction.json
description: |
  Sets the localized name of the MCP Server.
properties:
  name?:
    type: LocalizedString
    description: |
      Value to set. If empty or absent, the existing name is removed.
