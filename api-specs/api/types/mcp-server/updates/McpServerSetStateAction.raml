#%RAML 1.0 DataType
(package): McpServer
type: McpServerUpdateAction
displayName: McpServerSetStateAction
discriminatorValue: setState
example: !include ../../../examples/McpServer/McpServerSetStateAction.json
description: |
  Sets the [state](ctp:api:type:McpServerState) of the MCP Server. A `Disabled` MCP Server rejects all AI agent tool requests.
properties:
  state:
    type: McpServerState
    description: |
      New state to set.
