#%RAML 1.0 DataType
(package): McpServer
type: McpServerUpdateAction
displayName: McpServerAddToolAction
discriminatorValue: addTool
example: !include ../../../examples/McpServer/McpServerAddToolAction.json
description: |
  Adds a single tool to the MCP Server's list of enabled tools. Has no effect if the tool is already present.
properties:
  tool:
    type: McpServerTool
    description: |
      Name of the tool to add, such as `read_products` or `create_orders`.
