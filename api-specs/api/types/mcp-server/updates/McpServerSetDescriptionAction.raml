#%RAML 1.0 DataType
(package): McpServer
type: McpServerUpdateAction
displayName: McpServerSetDescriptionAction
discriminatorValue: setDescription
example: !include ../../../examples/McpServer/McpServerSetDescriptionAction.json
description: |
  Sets the localized description of the MCP Server.
properties:
  description?:
    type: LocalizedString
    description: |
      Value to set. If empty or absent, the existing description is removed.
