#%RAML 1.0 DataType
(package): McpServer
type: McpServerUpdateAction
displayName: McpServerSetToolsAction
discriminatorValue: setTools
example: !include ../../../examples/McpServer/McpServerSetToolsAction.json
description: |
  Replaces the entire list of tools enabled for the MCP Server.
properties:
  tools:
    type: array
    items: McpServerTool
    description: |
      New list of tools to set. Replaces the existing `tools` list entirely.
      Use `all` to enable all available tools, or specify individual tool names such as `read_products` or `create_orders`.
