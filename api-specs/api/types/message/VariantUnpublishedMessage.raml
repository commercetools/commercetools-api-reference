#%RAML 1.0 DataType
(package): Message
type: Message
(beta): true
displayName: VariantUnpublishedMessage
discriminatorValue: VariantUnpublished
description: |
  Generated after a successful [Unpublish](/../api/projects/variants#unpublish) update action.
properties:
  product:
    type: ProductReference
    description: |
      Reference to the Product containing the Variant that was unpublished.
