#%RAML 1.0 DataType
(package): PaymentMethod
type: PaymentMethodUpdateAction
displayName: PaymentMethodSetMethodAction
discriminatorValue: setMethod
example: !include ../../../examples/PaymentMethod/PaymentMethodSetMethodAction.json
description: |
  This action generates the [PaymentMethodMethodSet](ctp:api:type:PaymentMethodMethodSetMessage) Message.
properties:
  method?:
    type: string
    description: |
      New payment method—for example, a credit card or direct debit.
      If empty, any existing value will be removed.
