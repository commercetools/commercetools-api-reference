#%RAML 1.0 DataType
(package): Error
type: ErrorObject
displayName: MissingDependencyError
discriminatorValue: MissingDependency
(beta): true
example: !include ../../examples/Error/MissingDependency.json
description: |
  Returned when a referenced Extension does not exist or is not applicable to the same trigger.
properties:
  code:
    type: string
  message:
    type: string
    description: |
      `"The extensions '[ext-1, ext-2]' referenced in 'dependencies' do not exist."`
