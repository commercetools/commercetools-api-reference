#%RAML 1.0 DataType
(package): Error
type: ErrorObject
displayName: CircularDependencyError
discriminatorValue: CircularDependency
(beta): true
example: !include ../../examples/Error/CircularDependency.json
description: |
  Returned when a circular reference is detected among Extension dependencies.
properties:
  code:
    type: string
  message:
    type: string
    description: |
      `"Circular dependency detected: [ext-1, ext-2, ext-1]"`
