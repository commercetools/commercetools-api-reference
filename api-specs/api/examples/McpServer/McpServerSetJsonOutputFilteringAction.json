{
  "action": "setJsonOutputFiltering",
  "jsonOutputFiltering": {
    "redact": { "fieldNameContains": ["phone", "password"] },
    "drop": { "fieldNames": ["billingAddress", "shippingAddress", "paymentInfo", "createdBy", "lastModifiedBy"] },
    "fieldPathsToKeep": ["customer.email", "order.orderNumber"],
    "redactedWith": "[REDACTED]"
  }
}
